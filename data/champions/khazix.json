    "spells": [
      {
        "key": "Q",
        "name": "孤獨的恐懼",
        "description": "對目標造成物理傷害。會對 <font color='#FFF673'>孤立</font> 目標造成更多傷害。如果他選擇<font color='#00DD33'>進化死神之爪</font>，對 <font color='#FFF673'>孤立</font>目標使用會返還部分冷卻時間。卡力斯的基礎攻擊和孤獨的恐懼距離範圍也會增加。",
        "imageUrl": "https://ddragon.leagueoflegends.com/cdn/16.7.1/img/spell/KhazixQ.png"
      },
      {
        "key": "W",
        "name": "虛空尖刺",
        "description": "卡力斯發射爆裂尖刺，對擊中敵人緩速並且造成物理傷害。卡力斯如果在爆炸半徑內，則會獲得治療效果。如果選擇<font color='#00DD33'>進化尖刺拷問</font>，虛空尖刺會在錐形範圍內射擊 3 發尖刺，緩速目標，並揭露隱形的敵人，持續 2 秒。<font color='#FFF673'>孤立</font>的目標會受到更多緩速。",
        "imageUrl": "https://ddragon.leagueoflegends.com/cdn/16.7.1/img/spell/KhazixW.png"
      },
      {
        "key": "E",
        "name": "掠翅飛躍",
        "description": "卡力斯奮身跳向目標區域，落地時對敵人造成物理傷害。如果施放的是進化技能<font color='#00DD33'> 進化飛翅</font>的話，飛躍距離會增加 200 ，冷卻時間會因為擊殺或助攻重置。",
        "imageUrl": "https://ddragon.leagueoflegends.com/cdn/16.7.1/img/spell/KhazixE.png"
      },
      {
        "key": "R",
        "name": "虛空突襲",
        "description": "每一個階段都允許卡力斯進化他其中一項能力，賦予特別的額外效果。當啟動虛空突襲時，卡力斯進入<font color='#91d7ee'>隱形</font>並觸發暗影殺機，同時增加跑速。如果他選擇<font color='#00DD33'>進化自適應化形</font>，虛空突襲將增加<font color='#91d7ee'>隱形</font> 的持續時間，且獲得額外的使用次數。",
        "imageUrl": "https://ddragon.leagueoflegends.com/cdn/16.7.1/img/spell/KhazixR.png"
      }
    ]
  },
