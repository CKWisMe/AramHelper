    "spells": [
      {
        "key": "Q",
        "name": "狂舞手雷",
        "description": "燼對敵人射出一枚魔法充能的高壓鋼瓶。最多能夠擊中四個敵人，每次彈跳中擊殺目標時，下次彈跳造成傷害增加。",
        "imageUrl": "https://ddragon.leagueoflegends.com/cdn/16.7.1/img/spell/JhinQ.png"
      },
      {
        "key": "W",
        "name": "致命伏筆",
        "description": "燼揮舞他的槍管，發射出超遠距離的一發子彈。這發子彈能夠穿透士兵和野怪，但會在擊中的第一個英雄停止。如果目標近期曾被燼的隊友、蓮華之罠或燼傷害的話將暫時被定身。",
        "imageUrl": "https://ddragon.leagueoflegends.com/cdn/16.7.1/img/spell/JhinW.png"
      },
      {
        "key": "E",
        "name": "魔幻時刻",
        "description": "燼放置一個隱形的蓮華之罠，當有人走過時陷阱會綻放。對附近敵人造成緩速，隨後爆炸放射出鋸齒花瓣造成傷害。<br><br><font color='#FFFFFF'>死之華－</font> 當燼擊殺敵方英雄時，蓮華之罠會在他們的屍體附近綻放。",
        "imageUrl": "https://ddragon.leagueoflegends.com/cdn/16.7.1/img/spell/JhinE.png"
      },
      {
        "key": "R",
        "name": "華麗謝幕",
        "description": "燼準備施放技能，將低語完整組裝為肩射式的超級大砲。能夠在極限範圍內發射能夠穿透士兵和野怪的四發強化子彈，但在遇到英雄時停止。低語能夠致殘擊中的敵人，對他們造成緩速和斬殺傷害。第四發子彈經過完美的強化，必定造成暴擊。",
        "imageUrl": "https://ddragon.leagueoflegends.com/cdn/16.7.1/img/spell/JhinR.png"
      }
    ]
