    "spells": [
      {
        "key": "Q",
        "name": "骨頭迴力鏢／巨岩拋擲",
        "description": "吶兒丟出骨頭迴力鏢，在迴力鏢回到自己身上之前造成傷害並緩速敵人。如果他接到迴力鏢的話，該技能冷卻時間將會減少。<br><br>狂暴吶兒會丟出巨大岩石，巨石命中第一個目標後就會停住，緩速周圍所有敵方單位。可以把巨石撿起來，減少該技能冷卻時間。",
        "imageUrl": "https://ddragon.leagueoflegends.com/cdn/16.7.1/img/spell/GnarQ.png"
      },
      {
        "key": "W",
        "name": "野獸本能／原始衝撞",
        "description": "吶兒的攻擊與技能將會激怒他，造成額外傷害與獲得額外跑速。<br><br>狂暴吶兒已經呈現暴怒狀態，無法再次被激怒，但他能立起他的後腿並且推擊他前方的區域，暈眩該區域敵人。",
        "imageUrl": "https://ddragon.leagueoflegends.com/cdn/16.7.1/img/spell/GnarW.png"
      },
      {
        "key": "E",
        "name": "吶兒跳跳／重磅輾壓",
        "description": "吶兒奮力一跳到指定地點並且蹦蹦跳跳地從任何單位頭上翻過。<br><br>狂暴吶兒太巨大了，無法從頭上越過任何單位，反之，他會用一股粉碎地面的重力狠狠砸向目標，對該區域造成傷害。",
        "imageUrl": "https://ddragon.leagueoflegends.com/cdn/16.7.1/img/spell/GnarE.png"
      },
      {
        "key": "R",
        "name": "狂嘯猛擊！",
        "description": "狂暴吶兒將會把身邊的一切都丟往指定方向，造成傷害並緩速附近敵方單位。任何因此撞到牆上的敵人都會被暈眩，受到額外傷害。",
        "imageUrl": "https://ddragon.leagueoflegends.com/cdn/16.7.1/img/spell/GnarR.png"
