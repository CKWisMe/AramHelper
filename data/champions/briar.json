    "spells": [
      {
        "key": "Q",
        "name": "沖昏頭",
        "description": "布蕾爾跳向目標，用腳跟重擊敵軍造成傷害，將其擊暈，並削弱其物理防禦。",
        "imageUrl": "https://ddragon.leagueoflegends.com/cdn/16.7.1/img/spell/BriarQ.png"
      },
      {
        "key": "W",
        "name": "嗜血狂熱／進擊的點心",
        "description": "布蕾爾跳向前方並打破自己的枷鎖，進入嗜血狂熱狀態，不停追逐最靠近的敵軍 (以英雄為優先)。處於嗜血狂熱狀態時，布蕾爾的攻速和跑速會增加，且普攻會對目標周圍的敵軍造成傷害。<br><br>在嗜血狂熱狀態下重施此技能後，布蕾爾的下一次普攻會大口撕咬目標，根據目標已損失的生命額外造成傷害，並根據造成的傷害回復自身生命。",
        "imageUrl": "https://ddragon.leagueoflegends.com/cdn/16.7.1/img/spell/BriarW.png"
      },
      {
        "key": "E",
        "name": "破膽尖嘯",
        "description": "布蕾爾再次集中精神，脫離嗜血狂熱狀態，蓄力發出尖叫，緩速敵軍並造成傷害。蓄力期間，布蕾爾受到的傷害會降低，並會根據最大生命回復部分生命。完全蓄力後，尖叫會擊退敵軍，暈眩撞上牆面的敵軍並額外造成傷害。",
        "imageUrl": "https://ddragon.leagueoflegends.com/cdn/16.7.1/img/spell/BriarE.png"
      },
      {
        "key": "R",
        "name": "必死無疑",
        "description": "布蕾爾踢出枷鎖的血色石，將第一名命中的英雄標記為獵物，然後直接衝向對方，追到目標時對周圍的其他敵軍造成恐懼效果，並進入嗜血如命狀態。她會不斷追殺獵物，直到其中一方死亡為止，並會獲得嗜血狂熱增益，並增加物理防禦、魔法防禦、普攻吸血及跑速。",
        "imageUrl": "https://ddragon.leagueoflegends.com/cdn/16.7.1/img/spell/BriarR.png"
      }
    ]
  },
